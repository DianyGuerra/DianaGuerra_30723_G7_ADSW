generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE

  @@map("employee_status")
}

enum ClientStatus {
  ACTIVE
  INACTIVE

  @@map("client_status")
}

enum ClientType {
  NATURAL
  JURIDICAL

  @@map("client_type")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("quote_status")
}

enum ReservationStatus {
  BLOCKED
  RELEASED

  @@map("reservation_status")
}

enum InventoryMovementType {
  IN
  OUT
  COST_UPDATE

  @@map("inventory_movement_type")
}

enum ServiceCatalogType {
  SERVICE
  PRODUCT

  @@map("service_catalog_type")
}

enum PromotionStatus {
  ACTIVE
  INACTIVE

  @@map("promotion_status")
}

model Employee {
  id             String          @id @default(uuid()) @db.Uuid
  identification String          @unique
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  email          String          @unique
  phone          String?
  address        String?
  position       String?
  status         EmployeeStatus  @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User?
  roles          EmployeeRole[]
  quotes         Quote[]         @relation("CreatedQuotes")
  clients        Client[]        @relation("CreatedClients")

  @@map("employees")
}

model Role {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @unique
  description String?
  employees   EmployeeRole[]

  @@map("roles")
}

model EmployeeRole {
  employeeId String   @map("employee_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@map("employee_roles")
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  username       String    @unique
  passwordHash   String    @map("password_hash")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  isActive       Boolean   @default(true) @map("is_active")
  employeeId     String?   @unique @map("employee_id") @db.Uuid
  employee       Employee? @relation(fields: [employeeId], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  type           ClientType   @default(NATURAL)
  fullName       String       @map("full_name")
  identification String       @unique
  email          String
  phone          String
  address        String
  status         ClientStatus @default(ACTIVE)
  privacyConsent Boolean      @default(true) @map("privacy_consent")
  createdById    String?      @map("created_by_id") @db.Uuid
  createdBy      Employee?    @relation("CreatedClients", fields: [createdById], references: [id])
  quotes         Quote[]
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("clients")
}

model CatalogPackage {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @unique
  description   String        @default("")
  eventTypes    String[]      @map("event_types")
  marginPercent Decimal       @default(0) @map("margin_percent") @db.Decimal(5, 2)
  basePrice     Decimal?      @map("base_price") @db.Decimal(10, 2)
  pricePerChild Decimal?      @map("price_per_child") @db.Decimal(10, 2)
  minChildren   Int?          @map("min_children")
  capacityMax   Int?          @map("capacity_max")
  active        Boolean       @default(true)
  items         CatalogItem[]
  promotions    PromotionPackage[]

  @@map("catalog_packages")
}

model CatalogItem {
  id        String          @id @default(uuid()) @db.Uuid
  packageId String?         @map("package_id") @db.Uuid
  package   CatalogPackage? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  unit      String?
  quantity  Int             @default(1)
  basePrice Decimal         @default(0) @map("base_price") @db.Decimal(10, 2)

  @@map("catalog_items")
}

model InventoryItem {
  id          String              @id @default(uuid()) @db.Uuid
  name        String              @unique
  unit        String
  brand       String?
  currentCost Decimal             @default(0) @map("current_cost") @db.Decimal(10, 2)
  stock       Int                 @default(0)
  active      Boolean             @default(true)
  movements   InventoryMovement[]
  recipeComponents ServiceRecipeComponent[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("inventory_items")
}

model InventoryMovement {
  id              String          @id @default(uuid()) @db.Uuid
  inventoryItemId String          @map("inventory_item_id") @db.Uuid
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            InventoryMovementType
  quantity        Int             @default(0)
  previousCost    Decimal         @default(0) @map("previous_cost") @db.Decimal(10, 2)
  newCost         Decimal         @default(0) @map("new_cost") @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@map("inventory_movements")
}

model ServiceCatalog {
  id              String                @id @default(uuid()) @db.Uuid
  type            ServiceCatalogType
  name            String                @unique
  description     String
  suggestedPrice  Decimal               @default(0) @map("suggested_price") @db.Decimal(10, 2)
  active          Boolean               @default(true)
  components      ServiceRecipeComponent[]
  promotions      PromotionService[]
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@map("service_catalog")
}

model ServiceRecipeComponent {
  id              String          @id @default(uuid()) @db.Uuid
  serviceId       String          @map("service_id") @db.Uuid
  service         ServiceCatalog  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  inventoryItemId String?         @map("inventory_item_id") @db.Uuid
  inventoryItem   InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  name            String
  unit            String?
  quantity        Int             @default(1)
  unitCost        Decimal         @default(0) @map("unit_cost") @db.Decimal(10, 2)

  @@map("service_recipe_components")
}

model Promotion {
  id             String               @id @default(uuid()) @db.Uuid
  name           String               @unique
  discountPercent Decimal             @map("discount_percent") @db.Decimal(5, 2)
  startDate      DateTime             @map("start_date") @db.Date
  endDate        DateTime             @map("end_date") @db.Date
  allowedDays    String[]             @default([]) @map("allowed_days")
  minAmount      Decimal?             @map("min_amount") @db.Decimal(10, 2)
  active         Boolean              @default(true)
  packages       PromotionPackage[]
  services       PromotionService[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@map("promotions")
}

model PromotionPackage {
  promotionId String    @map("promotion_id") @db.Uuid
  packageId   String    @map("package_id") @db.Uuid
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  package     CatalogPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@id([promotionId, packageId])
  @@map("promotion_packages")
}

model PromotionService {
  promotionId String          @map("promotion_id") @db.Uuid
  serviceId   String          @map("service_id") @db.Uuid
  promotion   Promotion       @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service     ServiceCatalog   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
  @@map("promotion_services")
}

model Quote {
  id          String             @id @default(uuid()) @db.Uuid
  code        String             @unique
  clientId    String             @map("client_id") @db.Uuid
  client      Client             @relation(fields: [clientId], references: [id])
  eventDate   DateTime           @map("event_date") @db.Date
  eventType   String             @map("event_type")
  status      QuoteStatus        @default(DRAFT)
  version     Int                @default(1)
  subtotal    Decimal            @default(0) @db.Decimal(10, 2)
  tax         Decimal            @default(0) @db.Decimal(10, 2)
  discount    Decimal            @default(0) @db.Decimal(10, 2)
  total       Decimal            @default(0) @db.Decimal(10, 2)
  validUntil  DateTime           @map("valid_until") @db.Date
  notes       String?
  createdById String?            @map("created_by_id") @db.Uuid
  createdBy   Employee?          @relation("CreatedQuotes", fields: [createdById], references: [id])
  items       QuoteItem[]
  reservation EventReservation?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(uuid()) @db.Uuid
  quoteId     String  @map("quote_id") @db.Uuid
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  category    String?
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0) @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal @default(0) @db.Decimal(10, 2)

  @@map("quote_items")
}

model EventReservation {
  id        String            @id @default(uuid()) @db.Uuid
  quoteId   String            @unique @map("quote_id") @db.Uuid
  quote     Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  eventDate DateTime          @map("event_date") @db.Date
  status    ReservationStatus @default(BLOCKED)
  reason    String?
  createdAt DateTime          @default(now()) @map("created_at")

  @@map("event_reservations")
}
